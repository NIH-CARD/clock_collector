# Streamlit secrets template.
#
# DO NOT put a real key in THIS file — it is committed to the repo.
#
# Local dev:  copy this to .streamlit/secrets.toml (gitignored) and fill it in,
#             or just `export ANTHROPIC_API_KEY=...`.
# Streamlit Community Cloud:  paste the key into the app's
#             Settings -> Secrets dashboard (same TOML format). Never commit it.
#
# app.py reads it via st.secrets["ANTHROPIC_API_KEY"].

ANTHROPIC_API_KEY = "sk-ant-your-key-here"
